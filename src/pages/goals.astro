---
import Layout from '../layouts/Layout.astro';
import MyButton from '../components/button.jsx';
import "../styles/global.css";
---

<Layout>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap');

    :root {
      --bg: #0c0f14;
      --surface: #141920;
      --surface2: #1c2330;
      --border: rgba(255,255,255,0.07);
      --text: #e8edf5;
      --muted: #6b7a99;
      --blue: #4f8eff;
      --green: #2dca8a;
      --amber: #f5a623;
      --red: #ff5e5e;
      --purple: #a78bfa;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
    }

    .goals-page {
      min-height: 100vh;
      background: var(--bg);
      padding: 48px 24px 80px;
    }

    .hero {
      text-align: center;
      margin-bottom: 56px;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--blue);
      background: rgba(79,142,255,0.1);
      border: 1px solid rgba(79,142,255,0.2);
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 20px;
    }

    .hero-eyebrow::before {
      content: '';
      width: 6px; height: 6px;
      background: var(--blue);
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.7); }
    }

    .hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      font-weight: 400;
      line-height: 1.1;
      color: var(--text);
      margin: 0 0 16px;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--blue);
    }

    .hero p {
      font-size: 1.05rem;
      color: var(--muted);
      max-width: 520px;
      margin: 0 auto 32px;
      line-height: 1.7;
    }

    .goals-grid {
      display: grid;
      gap: 24px;
    }

    @media (min-width: 1024px) {
      .goals-grid {
        grid-template-columns: 1.15fr 0.85fr;
      }
    }

    .form-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 32px;
    }

    .form-card h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--text);
      margin: 0 0 24px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
    }

    .form-group label {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px 16px;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--blue);
    }

    .form-group input::placeholder {
      color: var(--muted);
    }

    .form-group select option {
      background: var(--surface2);
      color: var(--text);
    }

    .form-grid {
      display: grid;
      gap: 20px;
    }

    @media (min-width: 768px) {
      .form-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    .form-buttons {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      padding-top: 8px;
    }

    .form-message {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      text-align: center;
    }

    .form-message.success {
      color: var(--green);
    }

    .form-message.error {
      color: var(--red);
    }

    .suggestions-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 28px;
    }

    .suggestions-card h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--text);
      margin: 0 0 12px;
    }

    .suggestions-card > p {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.6;
      margin: 0 0 20px;
    }

    .suggestion-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .suggestion-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 20px;
    }

    .suggestion-card .label {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .suggestion-card.blue .label { color: var(--blue); }
    .suggestion-card.green .label { color: var(--green); }
    .suggestion-card.purple .label { color: var(--purple); }
    .suggestion-card.amber .label { color: var(--amber); }

    .suggestion-card h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.1rem;
      font-weight: 400;
      color: var(--text);
      margin: 0 0 8px;
    }

    .suggestion-card p {
      font-size: 0.85rem;
      color: var(--muted);
      line-height: 1.5;
      margin: 0;
    }

    .info-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 28px;
    }

    .info-card h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--text);
      margin: 0 0 12px;
    }

    .info-card p {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.6;
      margin: 0;
    }

    /* ── Current Goals Section ── */
    .current-goals-section {
      margin-top: 56px;
    }

    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    .section-header-left {
      display: flex;
      align-items: baseline;
      gap: 14px;
    }

    .section-header h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.75rem;
      font-weight: 400;
      color: var(--text);
      margin: 0;
    }

    .goals-count-pill {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--blue);
      background: rgba(79,142,255,0.1);
      border: 1px solid rgba(79,142,255,0.18);
      padding: 3px 10px;
      border-radius: 100px;
    }

    .current-goals-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    .goal-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      transition: border-color 0.25s, transform 0.25s;
      position: relative;
    }

    .goal-item:hover {
      border-color: rgba(79,142,255,0.3);
      transform: translateY(-3px);
    }

    .goal-item-accent {
      height: 3px;
      width: 100%;
      flex-shrink: 0;
    }

    .accent-screen-time { background: var(--purple); }
    .accent-phone-use   { background: var(--blue); }
    .accent-activity    { background: var(--green); }
    .accent-sleep       { background: var(--amber); }
    .accent-default     { background: var(--muted); }

    .goal-item-body {
      padding: 22px 24px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      flex: 1;
    }

    .goal-item-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .goal-category-badge {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding: 3px 9px;
      border-radius: 100px;
      white-space: nowrap;
    }

    .badge-screen-time  { background: rgba(167,139,250,0.12); color: var(--purple); border: 1px solid rgba(167,139,250,0.2); }
    .badge-phone-use    { background: rgba(79,142,255,0.12);  color: var(--blue);   border: 1px solid rgba(79,142,255,0.2); }
    .badge-activity     { background: rgba(45,202,138,0.12);  color: var(--green);  border: 1px solid rgba(45,202,138,0.2); }
    .badge-sleep        { background: rgba(245,166,35,0.12);  color: var(--amber);  border: 1px solid rgba(245,166,35,0.2); }
    .badge-default      { background: rgba(107,122,153,0.12); color: var(--muted);  border: 1px solid rgba(107,122,153,0.2); }

    .goal-duration-inline {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.1em;
      color: var(--muted);
    }

    .goal-item-title {
      font-family: 'DM Serif Display', serif;
      font-size: 1.15rem;
      font-weight: 400;
      color: var(--text);
      line-height: 1.3;
      margin: 0;
    }

    .goal-item-why {
      font-size: 0.84rem;
      color: var(--muted);
      line-height: 1.6;
      margin: 0;
      flex: 1;
    }

    .goal-item-footer {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 12px 24px 16px;
      border-top: 1px solid var(--border);
    }

    .goal-delete-btn {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--muted);
      font-size: 0.78rem;
      font-family: 'DM Mono', monospace;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 5px 10px;
      border-radius: 8px;
      transition: color 0.2s, background 0.2s;
    }

    .goal-delete-btn:hover {
      color: var(--red);
      background: rgba(255,94,94,0.07);
    }

    .goals-empty {
      grid-column: 1 / -1;
      text-align: center;
      padding: 64px 24px;
      color: var(--muted);
      font-size: 0.9rem;
      border: 1px dashed rgba(255,255,255,0.08);
      border-radius: 20px;
      line-height: 1.7;
    }

    .goals-empty strong {
      display: block;
      font-family: 'DM Serif Display', serif;
      font-size: 1.2rem;
      font-weight: 400;
      color: var(--text);
      margin-bottom: 6px;
    }

    .goals-loading {
      grid-column: 1 / -1;
      text-align: center;
      padding: 48px;
      color: var(--muted);
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }
  </style>

  <section class="goals-page">
    <div class="mx-auto flex max-w-6xl flex-col gap-8">
      
      <div class="hero">
        <p class="hero-eyebrow">Goals</p>
        <h1>
          Set sleep <em>improvement goals</em>
        </h1>
        <p>
          Create your own goals and get suggestions based on the daily habits that may affect your deep sleep.
        </p>
      </div>

      <div class="goals-grid">
        
        <div class="form-card">
          <h2>Create your own goal</h2>

          <form id="goal-form" class="grid gap-6">
            <div class="form-group">
              <label>Goal title</label>
              <input
                id="goal-title"
                type="text"
                placeholder="e.g. No caffeine after 3 PM"
              />
            </div>

            <div class="form-group">
              <label>Why do you want this goal?</label>
              <textarea
                id="goal-why"
                rows="4"
                placeholder="e.g. I think late coffee is reducing my deep sleep."
              ></textarea>
            </div>

            <div class="form-grid">
              <div class="form-group">
                <label>Category</label>
                <select id="goal-category">
                  <option value="">Select category</option>
                  <option value="screen-time">Screen time</option>
                  <option value="phone-use">Phone use</option>
                  <option value="activity">Physical activity</option>
                  <option value="sleep">Sleep routine</option>
                </select>
              </div>

              <div class="form-group">
                <label>Target duration</label>
                <select id="goal-duration">
                  <option value="">Select duration</option>
                  <option value="3days">3 days</option>
                  <option value="1week">1 week</option>
                  <option value="2weeks">2 weeks</option>
                  <option value="1month">1 month</option>
                  <option value="3months">3 months</option>
                  <option value="6months">6 months</option>
                </select>
              </div>
            </div>

            <p id="goal-message" class="form-message"></p>

            <div class="form-buttons">
              <MyButton type="submit" name="Save Goal" />
              <a href="/dashboard">
                <MyButton name="Back to Dashboard" />
              </a>
            </div>
          </form>
        </div>

        <div class="flex flex-col gap-6">
          <div class="suggestions-card">
            <h2>Suggested goals</h2>
            <p>
              Suggestions can adapt to patterns detected in the user's daily entries.
            </p>

            <div class="suggestion-list">
              <div class="suggestion-card green">
                <p class="label">Activity pattern</p>
                <h3>Reach 8,000 steps daily</h3>
                <p>
                  Useful if low-activity days seem related to worse sleep quality.
                </p>
              </div>

              <div class="suggestion-card purple">
                <p class="label">Screen routine</p>
                <h3>Reduce screen time in the evening</h3>
                <p>
                  Useful if high screen time or late phone use appears before poor sleep nights.
                </p>
              </div>

              <div class="suggestion-card amber">
                <p class="label">Sleep consistency</p>
                <h3>Keep a more regular bedtime</h3>
                <p>
                  Useful if irregular routines are linked with shorter or lower-quality sleep.
                </p>
              </div>
            </div>
          </div>

          <div class="info-card">
            <h2>How suggestions work</h2>
            <p>
              The system compares daily habits such as steps, screen time,
              and last phone use time with sleep outcomes to propose useful goals for behavior change.
            </p>
          </div>
        </div>
      </div>

      <!-- Current Goals Section -->
      <div class="current-goals-section">
        <div class="section-header">
          <div class="section-header-left">
            <h2>Current goals</h2>
            <span class="goals-count-pill" id="goals-count-label" style="display:none"></span>
          </div>
        </div>
        <div class="current-goals-grid" id="current-goals-grid">
          <div class="goals-loading">Loading goals…</div>
        </div>
      </div>

    </div>
  </section>

  <script>
    import { supabase } from "../../utils/supabase";

    const form    = document.getElementById("goal-form");
    const message = document.getElementById("goal-message");

    const DURATION_LABELS: Record<string, string> = {
      "3days":    "3 days",
      "1week":    "1 week",
      "2weeks":   "2 weeks",
      "1month":   "1 month",
      "3months":  "3 months",
      "6months":  "6 months",
    };

    const CATEGORY_BADGE: Record<string, string> = {
      "screen-time": "badge-screen-time",
      "phone-use":   "badge-phone-use",
      "activity":    "badge-activity",
      "sleep":       "badge-sleep",
    };

    const CATEGORY_LABEL: Record<string, string> = {
      "screen-time": "Screen time",
      "phone-use":   "Phone use",
      "activity":    "Physical activity",
      "sleep":       "Sleep routine",
    };

    // ── Fetch & render goals ──────────────────────────────────────
    async function loadGoals() {
      const grid  = document.getElementById("current-goals-grid")!;
      const count = document.getElementById("goals-count-label")!;

      const { data, error } = await supabase
        .from("Goals")
        .select("*")
        .order("id", { ascending: false });

      if (error) {
        grid.innerHTML = `<div class="goals-empty"><strong>Could not load goals</strong>Something went wrong fetching your goals.</div>`;
        return;
      }

      if (!data || data.length === 0) {
        (count as HTMLElement).style.display = "none";
        grid.innerHTML = `<div class="goals-empty"><strong>No goals yet </strong>Create your first goal above and it will appear here.</div>`;
        return;
      }

      (count as HTMLElement).style.display = "";
      count.textContent = `${data.length} active`;

      const ACCENT: Record<string, string> = {
        "screen-time": "accent-screen-time",
        "phone-use":   "accent-phone-use",
        "activity":    "accent-activity",
        "sleep":       "accent-sleep",
      };

      grid.innerHTML = data.map((g: any) => {
        const badgeClass  = CATEGORY_BADGE[g.category] ?? "badge-default";
        const badgeLabel  = CATEGORY_LABEL[g.category] ?? (g.category ?? "");
        const duration    = DURATION_LABELS[g.duration] ?? (g.duration ?? "");
        const accentClass = ACCENT[g.category] ?? "accent-default";

        return `
          <div class="goal-item" data-id="${g.id}">
            <div class="goal-item-accent ${accentClass}"></div>
            <div class="goal-item-body">
              <div class="goal-item-meta">
                ${badgeLabel ? `<span class="goal-category-badge ${badgeClass}">${escapeHtml(badgeLabel)}</span>` : `<span></span>`}
                ${duration ? `<span class="goal-duration-inline">${escapeHtml(duration)}</span>` : ""}
              </div>
              <p class="goal-item-title">${escapeHtml(g.goal_title ?? "")}</p>
              ${g.why ? `<p class="goal-item-why">${escapeHtml(g.why)}</p>` : ""}
            </div>
            <div class="goal-item-footer">
              <button class="goal-delete-btn" data-id="${g.id}">Remove</button>
            </div>
          </div>
        `;
      }).join("");

      // Attach delete handlers
      grid.querySelectorAll(".goal-delete-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const id = (btn as HTMLElement).dataset.id;
          if (!id) return;
          const { error } = await supabase.from("Goals").delete().eq("id", id);
          if (!error) loadGoals();
        });
      });
    }

    function escapeHtml(str: string) {
      return str.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
    }

    // ── Form submit ───────────────────────────────────────────────
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const titleEl    = document.getElementById("goal-title");
      const whyEl      = document.getElementById("goal-why");
      const categoryEl = document.getElementById("goal-category");
      const durationEl = document.getElementById("goal-duration");

      const goal_title = titleEl instanceof HTMLInputElement     ? titleEl.value.trim()    : "";
      const why        = whyEl instanceof HTMLTextAreaElement    ? whyEl.value.trim()      : "";
      const category   = categoryEl instanceof HTMLSelectElement ? categoryEl.value.trim() : "";
      const duration   = durationEl instanceof HTMLSelectElement ? durationEl.value.trim() : "";

      if (!goal_title) {
        message!.className = "form-message error";
        message!.textContent = "Please enter a goal title.";
        return;
      }

      message!.className = "form-message";
      message!.textContent = "Saving…";

      const { error } = await supabase.from("Goals").insert([{
        goal_title: goal_title || null,
        why:        why        || null,
        category:   category   || null,
        duration:   duration   || null,
      }]);

      if (error) {
        console.error(error);
        message!.className = "form-message error";
        message!.textContent = error.message || "Could not save goal.";
        return;
      }

      message!.className = "form-message success";
      message!.textContent = "Goal saved!";
      (form as HTMLFormElement).reset();

      await loadGoals();

      setTimeout(() => {
        message!.textContent = "";
      }, 2000);
    });

    // ── Init ──────────────────────────────────────────────────────
    loadGoals();
  </script>
</Layout>