---
import Layout from '../layouts/Layout.astro';
import "../styles/global.css";
---

<Layout>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap');

  :root {
    --bg: #0c0f14;
    --surface: #141920;
    --surface2: #1c2330;
    --border: rgba(255,255,255,0.07);
    --text: #e8edf5;
    --muted: #6b7a99;
    --blue: #4f8eff;
    --green: #2dca8a;
    --amber: #f5a623;
    --red: #ff5e5e;
    --purple: #a78bfa;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
  }

  .page {
    min-height: 100vh;
    padding: 48px 24px 80px;
    background: var(--bg);
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .hero { text-align: center; }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blue);
    background: rgba(79,142,255,0.1);
    border: 1px solid rgba(79,142,255,0.2);
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }

  .eyebrow::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--blue);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  .hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 400;
    line-height: 1.1;
    color: var(--text);
    margin: 0 0 16px;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--blue);
  }

  .hero p {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 520px;
    margin: 0 auto 32px;
    line-height: 1.7;
  }

  .form-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 32px;
  }

  .form-section h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--text);
    margin: 0 0 20px;
  }

  .form-grid {
    display: grid;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 16px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--blue);
  }

  .form-group input::placeholder {
    color: var(--muted);
  }

  .form-group select option {
    background: var(--surface2);
    color: var(--text);
  }

  .form-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    padding-top: 24px;
  }

  .save-message {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    text-align: center;
    margin-top: 16px;
  }

  .save-message.success {
    color: var(--green);
  }

  .save-message.error {
    color: var(--red);
  }

  .btn-primary {
    background: var(--blue);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 100px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-primary:hover {
    background: rgba(79,142,255,0.8);
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 12px 24px;
    border-radius: 100px;
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn-ghost:hover {
    border-color: var(--blue);
    color: var(--blue);
  }
</style>

<div class="page">
  <div class="container">

    <!-- Hero -->
    <header class="hero">
      <div class="eyebrow">Daily Entry</div>
      <h1>New <em>Day</em> Entry</h1>
      <p>Add today's sleep and habit data to discover how your daily behavior affects deep sleep.</p>
    </header>

    <!-- Form card -->
    <div class="form-card">
      <form id="day-entry-form" class="grid gap-8">

        <!-- Sleep data -->
        <div class="form-section">
          <h2>Sleep data</h2>
          <div class="form-grid">
            <div class="form-group">
              <label>Date</label>
              <input id="date" name="date" type="date" />
            </div>
            <div class="form-group">
              <label>Total Sleep Hours</label>
              <input id="totalSleep" name="totalSleep" type="number"
                     step="0.5" min="0" max="24" placeholder="e.g. 7.5" />
            </div>
            <div class="form-group">
              <label>Deep Sleep (hours)</label>
              <input id="deepSleep" name="deepSleep" type="number"
                     step="0.1" min="0" max="24" placeholder="e.g. 1.8" />
            </div>
            <div class="form-group">
              <label>Sleep Quality</label>
              <select id="sleepQuality" name="sleepQuality">
                <option value="">Select quality</option>
                <option value="excellent">Excellent</option>
                <option value="good">Good</option>
                <option value="fair">Fair</option>
                <option value="poor">Poor</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Daily habits -->
        <div class="form-section">
          <h2>Daily habits</h2>
          <div class="form-grid">
            <div class="form-group">
              <label>Caffeine After 3 PM</label>
              <select id="caffeineAfter3" name="caffeineAfter3">
                <option value="">Select option</option>
                <option value="No">No</option>
                <option value="Yes">Yes</option>
              </select>
            </div>
            <div class="form-group">
              <label>Steps</label>
              <input id="steps" name="steps" type="number"
                     min="0" placeholder="e.g. 8500" />
            </div>
            <div class="form-group">
              <label>Screen Time (hours)</label>
              <input id="screenTime" name="screenTime" type="number"
                     step="0.1" min="0" max="24" placeholder="e.g. 4.2" />
            </div>
            <div class="form-group">
              <label>Last Phone Use Time</label>
              <input id="lastPhoneUse" name="lastPhoneUse" type="time" />
            </div>
          </div>
        </div>

        <!-- Reflection -->
        <div class="form-section">
          <h2>Reflection</h2>
          <div class="form-group">
            <label>Notes</label>
            <textarea id="notes" name="notes" rows="5"
              placeholder="Add anything important about your day or sleep."></textarea>
          </div>
        </div>

        <!-- Actions -->
        <div class="form-buttons">
          <button type="submit" class="btn-primary">Save Entry</button>
          <a href="/dashboard" class="btn-ghost">Back to Dashboard</a>
        </div>

        <p id="save-message" class="save-message"></p>

      </form>
    </div>

  </div>
</div>

<script>
  const form    = document.getElementById("day-entry-form")  as HTMLFormElement | null;
  const message = document.getElementById("save-message")    as HTMLElement | null;

  form?.addEventListener("submit", (event) => {
    event.preventDefault();

    const g = (id: string) => document.getElementById(id) as HTMLInputElement | null;

    const entry = {
      date:           g("date")?.value           || "",
      totalSleep:     Number(g("totalSleep")?.value  || 0),
      deepSleep:      Number(g("deepSleep")?.value   || 0),
      sleepQuality:   (document.getElementById("sleepQuality")  as HTMLSelectElement | null)?.value || "",
      caffeineAfter3: (document.getElementById("caffeineAfter3") as HTMLSelectElement | null)?.value || "",
      steps:          Number(g("steps")?.value       || 0),
      screenTime:     Number(g("screenTime")?.value  || 0),
      lastPhoneUse:   g("lastPhoneUse")?.value   || "",
      notes:          (document.getElementById("notes") as HTMLTextAreaElement | null)?.value || "",
    };

    const existing = JSON.parse(localStorage.getItem("sleepEntries") || "[]");
    existing.push(entry);
    localStorage.setItem("sleepEntries", JSON.stringify(existing));

    if (message) {
      message.textContent = "✓ Entry saved successfully";
      message.classList.add("visible");
    }

    form.reset();

    setTimeout(() => { window.location.href = "/visualisations"; }, 700);
  });
</script>

</Layout>
