    /* ─── Chart 06: Heatmap ─── */
    function renderHeatmap(data) {
  const valid = data.filter(d => d.deepSleep != null);
  done('load-heatmap', 'empty-heatmap', valid.length > 0);
  if (!valid.length) return;

  const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  function isoWeekKey(date) {
    const d = new Date(date);
    d.setHours(0,0,0,0);
    d.setDate(d.getDate() + 4 - (d.getDay() || 7));
    const year = d.getFullYear();
    const startOfYear = new Date(year, 0, 1);
    const week = Math.ceil((((d - startOfYear) / 86400000) + 1) / 7);
    return `${year}-${String(week).padStart(2,'0')}`;
  }

  // Group entries by ISO week, place in correct day column
  const weekMap = new Map();
  valid.forEach(d => {
    const key = isoWeekKey(d.date);
    if (!weekMap.has(key)) weekMap.set(key, new Array(7).fill(null));
    const col = (d.date.getDay() + 6) % 7;   // 0=Mon … 6=Sun
    weekMap.get(key)[col] = d;
  });

  const sortedWeeks = [...weekMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));
  const maxDeep = Math.max(...valid.map(d => d.deepSleep));

  function col(v) {
    if (v == null) return SURFACE2;
    const t = v / Math.max(maxDeep, 2.5);
    if (t < 0.5) {
      return `rgb(${Math.round(255*(1-t*0.6))},${Math.round(100+t*100)},80)`;
    } else {
      const u = (t-0.5)*2;
      return `rgb(${Math.round(255*(1-u)*0.4)},${Math.round(200+u*55)},${Math.round(80+u*50)})`;
    }
  }

  const inner = $('heatmap-inner');
  inner.innerHTML = '';

  // Header row
  inner.appendChild(Object.assign(document.createElement('div'), { className: 'hm-header' }));
  DAYS.forEach(d => {
    const el = document.createElement('div');
    el.className = 'hm-header';
    el.textContent = d;
    inner.appendChild(el);
  });

  // Week rows
  sortedWeeks.forEach(([key, week]) => {
    const firstDay = week.find(d => d != null);
    const lbl = document.createElement('div');
    lbl.className = 'hm-label';
    lbl.textContent = firstDay
      ? firstDay.date.toLocaleDateString('en-GB', { day:'numeric', month:'short' })
      : key.split('-')[1];
    inner.appendChild(lbl);

    week.forEach(day => {
      const cell = document.createElement('div');
      cell.className = 'hm-cell';
      cell.style.background = col(day?.deepSleep ?? null);
      cell.style.opacity = day ? '1' : '0.18';
      if (day) cell.dataset.tip = `${day.label}: ${day.deepSleep.toFixed(1)}h deep`;
      inner.appendChild(cell);
    });
  });

  $('legend-gradient').style.background =
    `linear-gradient(to right, rgb(255,100,80), rgb(245,166,35), rgb(45,202,138))`;
  show('heatmap-grid');
}


    /* ─── Chart 07: Day-of-week avg bar ─── */
function renderDOW(data) {
  const valid = data.filter(d=>d.deepSleep!=null);
  const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const byDay = DAYS.map(day=>{
    const group = valid.filter(d=>d.dow===day);
    return { day, avg: group.length ? group.reduce((s,d)=>s+d.deepSleep,0)/group.length : null, n: group.length };
  }).filter(d=>d.avg!=null);

  done('load-dow','empty-dow', byDay.length > 1);
  if (byDay.length <= 1) return;

  const w = Math.min($('chart-dow').parentElement.offsetWidth - 40, 900);
  const globalAvg = byDay.reduce((s,d)=>s+d.avg,0)/byDay.length;

  const chart = Plot.plot({
    width: w, height: 240,
    style: plotStyle,
    marginLeft: 50, marginRight: 10, marginTop: 10, marginBottom: 40,
    x: { label: null },
    y: {
      grid: true,
      label: null,                                  // ← removed
      domain:[0, Math.max(...byDay.map(d=>d.avg))+0.5],
      gridColor: 'rgba(255,255,255,0.06)'
    },
    marks: [
      Plot.ruleY([0], { stroke: 'rgba(255,255,255,0.08)' }),
      Plot.ruleY([globalAvg], { stroke: BLUE, strokeDasharray:'5,4', strokeOpacity:0.5, strokeWidth:1.5 }),
      Plot.barY(byDay, {
        x:'day', y:'avg',
        fill: d => d.avg >= globalAvg ? GREEN : AMBER,
        rx: 6, tip: true,
        title: d=>`${d.day}: ${d.avg.toFixed(1)}h avg deep sleep\n(${d.n} nights)`
      }),
      Plot.text([{x:'Sun',y:globalAvg}], {
        x:'x', y:'y', text:d=>`avg ${globalAvg.toFixed(1)}h`,
        fill: BLUE, fontSize:10, dy:-8, textAnchor:'end'
      })
    ]
  });

  const wrap = $('chart-dow');
  wrap.innerHTML = '';
  const lbl = document.createElement('div');
  lbl.textContent = '↑ Avg deep sleep (h)';
  lbl.style.cssText = `font-family:'DM Mono',monospace;font-size:11px;color:${MUTED};margin-bottom:4px;padding-left:4px;`;
  wrap.appendChild(lbl);
  wrap.appendChild(chart);
}


    /* ─── Main ─── */
    const data = await fetchData();
    console.log('Fetched', data.length, 'rows');

    renderStats(data);
    renderSleepTrend(data);
    renderDeepBar(data);
    renderCaffeine(data);
    renderSteps(data);
    renderScreen(data);
    renderHeatmap(data);
    renderDOW(data);

    // Resize handler
    let rt;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = setTimeout(() => {
        ['chart-sleep','chart-deep','chart-steps','chart-screen','chart-dow']
          .forEach(id => { const el=$(id); if(el) el.innerHTML=''; });
        renderSleepTrend(data);
        renderDeepBar(data);
        renderSteps(data);
        renderScreen(data);
        renderDOW(data);
      }, 280);
    });
