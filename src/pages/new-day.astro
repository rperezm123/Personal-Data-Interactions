---
import Layout from '../layouts/Layout.astro';
import MyButton from '../components/button.jsx';
import "../styles/global.css";
---

<Layout>
  <section class="min-h-screen bg-slate-50 px-6 py-10">
    <div class="mx-auto flex max-w-5xl flex-col gap-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">
          Daily Entry
        </p>
        <h1 class="mt-2 text-4xl font-extrabold text-slate-900 md:text-6xl">
          New Day Entry
        </h1>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
          Add today’s sleep and habit data to discover how your daily behavior affects deep sleep.
        </p>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
        <form id="day-entry-form" class="grid gap-8">
          <div>
            <h2 class="mb-4 text-2xl font-bold text-slate-900">Sleep data</h2>
            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <label class="mb-2 block font-semibold text-slate-800">Date</label>
                <input id="date" type="date" class="w-full rounded-xl border border-slate-300 px-4 py-3" />
              </div>

              <div>
                <label class="mb-2 block font-semibold text-slate-800">Total Sleep Hours</label>
                <input id="totalSleep" type="number" step="0.5" min="0" max="24" placeholder="e.g. 7.5" class="w-full rounded-xl border border-slate-300 px-4 py-3" />
              </div>

              <div>
                <label class="mb-2 block font-semibold text-slate-800">Deep Sleep (hours)</label>
                <input id="deepSleep" type="number" step="0.1" min="0" max="24" placeholder="e.g. 1.8" class="w-full rounded-xl border border-slate-300 px-4 py-3" />
              </div>

              <div>
                <label class="mb-2 block font-semibold text-slate-800">Sleep Quality</label>
                <select id="sleepQuality" class="w-full rounded-xl border border-slate-300 px-4 py-3">
                  <option value="">Select quality</option>
                  <option value="excellent">Excellent</option>
                  <option value="good">Good</option>
                  <option value="fair">Fair</option>
                  <option value="poor">Poor</option>
                </select>
              </div>
            </div>
          </div>

          <div>
            <h2 class="mb-4 text-2xl font-bold text-slate-900">Daily habits</h2>
            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <label class="mb-2 block font-semibold text-slate-800">Caffeine After 3 PM</label>
                <select id="caffeineAfter3" class="w-full rounded-xl border border-slate-300 px-4 py-3">
                  <option value="">Select option</option>
                  <option value="No">No</option>
                  <option value="Yes">Yes</option>
                </select>
              </div>

              <div>
                <label class="mb-2 block font-semibold text-slate-800">Steps</label>
                <input id="steps" type="number" min="0" placeholder="e.g. 8500" class="w-full rounded-xl border border-slate-300 px-4 py-3" />
              </div>

              <div>
                <label class="mb-2 block font-semibold text-slate-800">Screen Time (hours)</label>
                <input id="screenTime" type="number" step="0.1" min="0" max="24" placeholder="e.g. 4.2" class="w-full rounded-xl border border-slate-300 px-4 py-3" />
              </div>

              <div>
                <label class="mb-2 block font-semibold text-slate-800">Last Phone Use Time</label>
                <input id="lastPhoneUse" type="time" class="w-full rounded-xl border border-slate-300 px-4 py-3" />
              </div>
            </div>
          </div>

          <div>
            <h2 class="mb-4 text-2xl font-bold text-slate-900">Reflection</h2>
            <div>
              <label class="mb-2 block font-semibold text-slate-800">Notes</label>
              <textarea id="notes" rows="5" placeholder="Add anything important about your day or sleep." class="w-full rounded-xl border border-slate-300 px-4 py-3"></textarea>
            </div>
          </div>

          <div class="flex flex-wrap justify-center gap-4 pt-4">
            <MyButton type="submit" name="Save Entry" />
            <MyButton component="a" href="/dashboard" name="Back to Dashboard" />
          </div>

          <p id="save-message" class="text-center font-medium"></p>
        </form>
      </div>
    </div>
  </section>

  <script>
  import { supabase } from "../../utils/supabase";

  /**
   * Matches `public."Data"`: date, "Total_sleep", "Deep_sleep", "Sleep_quality",
   * "Caffeine", "Steps", "Screen" (all bigint except date/quality/time).
   * Sleep + screen hours from the form are stored as whole minutes in bigint columns.
   */
  function formToDataRow() {
    const dateEl = document.getElementById("date");
    const totalSleepEl = document.getElementById("totalSleep");
    const deepSleepEl = document.getElementById("deepSleep");
    const sleepQualityEl = document.getElementById("sleepQuality");
    const caffeineEl = document.getElementById("caffeineAfter3");
    const stepsEl = document.getElementById("steps");
    const screenTimeEl = document.getElementById("screenTime");
    const lastPhoneEl = document.getElementById("lastPhoneUse");

    const date = dateEl instanceof HTMLInputElement ? dateEl.value.trim() : "";
    const totalSleepRaw = totalSleepEl instanceof HTMLInputElement ? totalSleepEl.value : "";
    const deepSleepRaw = deepSleepEl instanceof HTMLInputElement ? deepSleepEl.value : "";
    const sleepQuality =
      sleepQualityEl instanceof HTMLSelectElement ? sleepQualityEl.value.trim() : "";
    const caffeineAfter3 =
      caffeineEl instanceof HTMLSelectElement ? caffeineEl.value.trim() : "";
    const stepsRaw = stepsEl instanceof HTMLInputElement ? stepsEl.value : "";
    const screenTimeRaw = screenTimeEl instanceof HTMLInputElement ? screenTimeEl.value : "";
    const lastPhoneUse =
      lastPhoneEl instanceof HTMLInputElement ? lastPhoneEl.value.trim() : "";

    /** Hours (possibly decimal) → integer minutes for bigint columns */
    function hoursToMinutesOrNull(raw = "") {
      if (raw === "") return null;
      const n = Number(raw);
      if (!Number.isFinite(n)) return null;
      return Math.round(n * 60);
    }

    function stepsOrNull(raw = "") {
      if (raw === "") return null;
      const n = Number(raw);
      if (!Number.isFinite(n)) return null;
      return Math.round(n);
    }

    function caffeineOrNull(yesNo = "") {
      if (yesNo === "Yes") return 1;
      if (yesNo === "No") return 0;
      return null;
    }

    function strOrNull(s = "") {
      return s === "" ? null : s;
    }

    return {
      date: date || null,
      Total_sleep: hoursToMinutesOrNull(totalSleepRaw),
      Deep_sleep: hoursToMinutesOrNull(deepSleepRaw),
      Sleep_quality: strOrNull(sleepQuality),
      Caffeine: caffeineOrNull(caffeineAfter3),
      Steps: stepsOrNull(stepsRaw),
      Screen: hoursToMinutesOrNull(screenTimeRaw),
      Last_phone_time: strOrNull(lastPhoneUse),
    };
  }

  const form = document.getElementById("day-entry-form");
  const message = document.getElementById("save-message");

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(form instanceof HTMLFormElement) || !(message instanceof HTMLParagraphElement)) return;

    const row = formToDataRow();
    if (!row.date) {
      message.className = "text-center font-medium text-red-600";
      message.textContent = "Please choose a date.";
      return;
    }

    message.className = "text-center font-medium text-slate-600";
    message.textContent = "Saving…";

    const { data: existing, error: checkError } = await supabase
      .from("Data")
      .select("id")
      .eq("date", row.date)
      .limit(1);

    if (checkError) {
      console.error(checkError);
      message.className = "text-center font-medium text-red-600";
      message.textContent = checkError.message || "Could not verify this date.";
      return;
    }

    if (existing && existing.length > 0) {
      message.className = "text-center font-medium text-red-600";
      message.textContent = "You already have an entry for this date. Pick another day or edit it in Supabase.";
      return;
    }

    const { error } = await supabase.from("Data").insert([row]);

    if (error) {
      console.error(error);
      message.className = "text-center font-medium text-red-600";
      if (error.code === "23505") {
        message.textContent = "An entry for this date already exists.";
        return;
      }
      message.textContent = error.message || "Could not save. Check table columns and RLS policies.";
      return;
    }

    message.className = "text-center font-medium text-emerald-600";
    message.textContent = "Entry saved successfully";
    form.reset();

    setTimeout(() => {
      window.location.href = "/visualisations";
    }, 700);
  });
</script>


</Layout>
