---
import Layout from '../layouts/Layout.astro';
import "../styles/global.css";
---

<Layout>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap');

    :root {
      --bg: #0c0f14;
      --surface: #141920;
      --surface2: #1c2330;
      --border: rgba(255,255,255,0.07);
      --text: #e8edf5;
      --muted: #6b7a99;
      --blue: #4f8eff;
      --green: #2dca8a;
      --amber: #f5a623;
      --red: #ff5e5e;
      --purple: #a78bfa;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
    }

    .form-page {
      min-height: 100vh;
      background: var(--bg);
      padding: 48px 24px 80px;
    }

    .form-page > div {
      max-width: 1000px;
      margin: 0 auto;
    }

    .hero {
      text-align: center;
      margin-bottom: 56px;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--blue);
      background: rgba(79,142,255,0.1);
      border: 1px solid rgba(79,142,255,0.2);
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 20px;
    }

    .hero-eyebrow::before {
      content: '';
      width: 6px; height: 6px;
      background: var(--blue);
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.7); }
    }

    .hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      font-weight: 400;
      line-height: 1.1;
      color: var(--text);
      margin: 0 0 16px;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--blue);
    }

    .hero p {
      font-size: 1.05rem;
      color: var(--muted);
      max-width: 520px;
      margin: 0 auto 32px;
      line-height: 1.7;
    }

    .form-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 32px;
    }

    .form-section h2 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.4rem;
      font-weight: 400;
      color: var(--text);
      margin: 0 0 32px;
    }

    .form-section {
      margin-bottom: 48px;
    }

    .form-section:last-child {
      margin-bottom: 0;
    }

    .form-grid {
      display: grid;
      gap: 20px;
    }

    @media (min-width: 768px) {
      .form-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .form-group {
      display: flex;
      flex-direction: column;
    }

    .form-group label {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px 16px;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--blue);
    }

    .form-group input::placeholder {
      color: var(--muted);
    }

    .form-group select option {
      background: var(--surface2);
      color: var(--text);
    }

    .fit-btn {
      background: rgba(79,142,255,0.1);
      border: 1px solid rgba(79,142,255,0.3);
      color: var(--blue);
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 12px 16px;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .fit-btn:hover:not(:disabled) {
      background: rgba(79,142,255,0.2);
      border-color: var(--blue);
    }

    .fit-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .fit-fetch-btn {
      background: rgba(45,202,138,0.1);
      border: 1px solid rgba(45,202,138,0.3);
      color: var(--green);
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 12px 16px;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .fit-fetch-btn:hover:not(:disabled) {
      background: rgba(45,202,138,0.2);
      border-color: var(--green);
    }

    .fit-fetch-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    .fit-status {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      text-align: center;
      margin-top: 8px;
    }

    .form-buttons {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      padding-top: 24px;
    }

    .save-message {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      text-align: center;
      margin-top: 16px;
    }

    .save-message.success {
      color: var(--green);
    }

    .save-message.error {
      color: var(--red);
    }

    .btn-primary {
      background: var(--blue);
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 100px;
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-primary:hover {
      background: rgba(79,142,255,0.8);
      transform: translateY(-1px);
    }

    .btn-ghost {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 12px 24px;
      border-radius: 100px;
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-ghost:hover {
      border-color: var(--blue);
      color: var(--blue);
    }
  </style>

  <section class="form-page">
    <div>
      <div class="hero">
        <p class="hero-eyebrow">Daily Entry</p>
        <h1>
          New Day <em>Entry</em>
        </h1>
        <p>
          Add today's sleep and habit data to discover how your daily behavior affects deep sleep.
        </p>
      </div>

      <div class="form-card">
        <form id="day-entry-form">
          <div class="form-section">
            <h2>Sleep data</h2>
            <div class="form-grid">
              <div class="form-group">
                <label>Date</label>
                <input id="date" type="date" />
              </div>

              <div class="form-group">
                <label>Auto-fill from Google Fit</label>
                <button
                  id="fitLoginBtn"
                  type="button"
                  class="fit-btn"
                >
                  1. Connect Google Fit
                </button>
              </div>

              <div class="form-group" style="grid-column: 1 / -1;">
                <button
                  id="fitFetchBtn"
                  type="button"
                  disabled
                  class="fit-fetch-btn"
                >
                  2. Fetch Steps &amp; Sleep for Selected Date
                </button>
                <p id="fit-status" class="fit-status"></p>
              </div>

              <div class="form-group">
                <label>Total Sleep Hours</label>
                <input id="totalSleep" type="number" step="0.1" min="0" max="24" placeholder="e.g. 7.5" />
              </div>

              <div class="form-group">
                <label>Deep Sleep (hours)</label>
                <input id="deepSleep" type="number" step="0.1" min="0" max="24" placeholder="e.g. 1.8" />
              </div>

              <div class="form-group">
                <label>Sleep Quality</label>
                <select id="sleepQuality">
                  <option value="">Select quality</option>
                  <option value="excellent">Excellent</option>
                  <option value="good">Good</option>
                  <option value="fair">Fair</option>
                  <option value="poor">Poor</option>
                </select>
              </div>
            </div>
          </div>

          <div class="form-section">
            <h2>Daily habits</h2>
            <div class="form-grid">
              <div class="form-group">
                <label>Steps</label>
                <input id="steps" type="number" min="0" placeholder="e.g. 8500" />
              </div>

              <div class="form-group">
                <label>Screen Time (hours)</label>
                <input id="screenTime" type="number" step="0.1" min="0" max="24" placeholder="e.g. 4.2" />
              </div>

              <div class="form-group">
                <label>Last Phone Use Time</label>
                <input id="lastPhoneUse" type="time" />
              </div>
            </div>
          </div>

          <div class="form-section">
            <h2>Reflection</h2>
            <div class="form-group">
              <label>Notes</label>
              <textarea id="notes" rows="5" placeholder="Add anything important about your day or sleep."></textarea>
            </div>
          </div>

          <div class="form-buttons">
            <button type="submit" class="btn-primary">Save Entry</button>
            <a href="/dashboard" class="btn-ghost">Back to Dashboard</a>
          </div>

          <p id="save-message" class="save-message"></p>
        </form>
      </div>
    </div>
  </section>

  <script src="https://accounts.google.com/gsi/client" async defer></script>

  <script type="module">
    let accessToken = null;

    const fitLoginBtn = document.getElementById("fitLoginBtn");
    const fitFetchBtn = document.getElementById("fitFetchBtn");
    const fitStatus   = document.getElementById("fit-status");
    const dateInput   = document.getElementById("date");

    function setStatus(msg, color = "text-slate-500") {
      fitStatus.className = `mt-2 text-center text-sm ${color}`;
      fitStatus.textContent = msg;
    }

    function updateFetchBtn() {
      const hasDate  = dateInput instanceof HTMLInputElement && dateInput.value !== "";
      fitFetchBtn.disabled = !(hasDate && accessToken);
    }

    dateInput?.addEventListener("change", updateFetchBtn);

    window.addEventListener("load", () => {
      const interval = setInterval(() => {
        if (window.google?.accounts) {
          clearInterval(interval);

          const tokenClient = google.accounts.oauth2.initTokenClient({
            client_id: "700516162297-v7k62thc9i25kbr94kjqf15ts0udkca2.apps.googleusercontent.com",
            scope: [
              "https://www.googleapis.com/auth/fitness.activity.read",
              "https://www.googleapis.com/auth/fitness.body.read",
              "https://www.googleapis.com/auth/fitness.sleep.read",
            ].join(" "),
            callback: (tokenResponse) => {
              accessToken = tokenResponse.access_token;
              fitLoginBtn.textContent = "✓ Connected to Google Fit";
              setStatus("Connected! Select a date then click Fetch.", "text-emerald-600");
              updateFetchBtn();
            },
          });

          fitLoginBtn.addEventListener("click", () => tokenClient.requestAccessToken());
        }
      }, 100);
    });

    fitFetchBtn?.addEventListener("click", async () => {
      if (!accessToken) return;
      const dateVal = dateInput instanceof HTMLInputElement ? dateInput.value : "";
      if (!dateVal) return;

      setStatus("Fetching from Google Fit…");
      fitFetchBtn.disabled = true;

      const [year, month, day] = dateVal.split("-").map(Number);

      // Day window: midnight to midnight of the selected date
      const dayStart = new Date(year, month - 1, day, 0, 0, 0, 0);
      const dayEnd   = new Date(year, month - 1, day, 23, 59, 59, 999);

      // Sleep window: noon the day before → noon the day after
      // This reliably captures any sleep session that overlaps the selected night
      const sleepStart = new Date(year, month - 1, day - 1, 12, 0, 0, 0);
      const sleepEnd   = new Date(year, month - 1, day + 1, 12, 0, 0, 0);

      try {
        // ── Steps: sum ALL points across ALL buckets ──────────────
        // Google sometimes splits the day into multiple buckets (e.g. across
        // a midnight boundary or data-source boundary). Summing all of them
        // matches what the Google Fit app shows.
        const stepsRes = await fetch(
          "https://www.googleapis.com/fitness/v1/users/me/dataset:aggregate",
          {
            method: "POST",
            headers: {
              Authorization: `Bearer ${accessToken}`,
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              aggregateBy: [{ dataTypeName: "com.google.step_count.delta" }],
              bucketByTime: { durationMillis: 86400000 },
              startTimeMillis: dayStart.getTime(),
              endTimeMillis: dayEnd.getTime(),
            }),
          }
        );
        const stepsData = await stepsRes.json();

        // Sum every intVal across every bucket and every point
        let steps = 0;
        for (const bucket of stepsData.bucket ?? []) {
          for (const dataset of bucket.dataset ?? []) {
            for (const point of dataset.point ?? []) {
              steps += point.value?.[0]?.intVal ?? 0;
            }
          }
        }

        // ── Sleep: use the Sessions API, not just aggregate ───────
        // The Sessions API returns actual recorded sleep sessions with
        // proper start/end times — much more reliable than aggregate buckets.
        // activityType=72 is "Sleep".
        const sessionsRes = await fetch(
          `https://www.googleapis.com/fitness/v1/users/me/sessions` +
          `?startTime=${sleepStart.toISOString()}&endTime=${sleepEnd.toISOString()}&activityType=72`,
          { headers: { Authorization: `Bearer ${accessToken}` } }
        );
        const sessionsData = await sessionsRes.json();
        const sessions = sessionsData.session ?? [];

        // Now fetch sleep segment detail for the same window so we can
        // tally deep sleep from the stage breakdown.
        const sleepSegRes = await fetch(
          "https://www.googleapis.com/fitness/v1/users/me/dataset:aggregate",
          {
            method: "POST",
            headers: {
              Authorization: `Bearer ${accessToken}`,
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              aggregateBy: [{ dataTypeName: "com.google.sleep.segment" }],
              // Use a single large bucket to get all points back in one place
              bucketByTime: { durationMillis: (sleepEnd - sleepStart) },
              startTimeMillis: sleepStart.getTime(),
              endTimeMillis: sleepEnd.getTime(),
            }),
          }
        );
        const sleepSegData = await sleepSegRes.json();

        // Stage values: 4 = light sleep, 5 = deep sleep, 6 = REM, 2 = generic sleep
        // 1 = awake (during sleep), 3 = out of bed — excluded from totals
        const ASLEEP = new Set([2, 4, 5, 6]);
        const DEEP   = new Set([5]);

        let totalSleepMs = 0;
        let deepSleepMs  = 0;

        // Prefer segment data (gives stage breakdown)
        const allPoints = [];
        for (const bucket of sleepSegData.bucket ?? []) {
          for (const dataset of bucket.dataset ?? []) {
            for (const point of dataset.point ?? []) {
              allPoints.push(point);
            }
          }
        }

        if (allPoints.length > 0) {
          for (const point of allPoints) {
            const stage = point.value?.[0]?.intVal;
            const ms = (Number(point.endTimeNanos) - Number(point.startTimeNanos)) / 1e6;
            if (ASLEEP.has(stage)) totalSleepMs += ms;
            if (DEEP.has(stage))   deepSleepMs  += ms;
          }
        } else if (sessions.length > 0) {
          // Fallback: no stage detail, use raw session duration
          for (const s of sessions) {
            totalSleepMs += Number(s.endTimeMillis) - Number(s.startTimeMillis);
          }
        }

        // Round to 1 decimal hour
        const toHours = (ms) => Math.round(ms / 360000) / 10;

        // ── Fill fields ───────────────────────────────────────────
        const stepsInput      = document.getElementById("steps");
        const totalSleepInput = document.getElementById("totalSleep");
        const deepSleepInput  = document.getElementById("deepSleep");

        if (stepsInput instanceof HTMLInputElement)
          stepsInput.value = steps > 0 ? String(steps) : "";

        if (totalSleepInput instanceof HTMLInputElement)
          totalSleepInput.value = totalSleepMs > 0 ? String(toHours(totalSleepMs)) : "";

        if (deepSleepInput instanceof HTMLInputElement)
          deepSleepInput.value = deepSleepMs > 0 ? String(toHours(deepSleepMs)) : "";

        // ── Status message ────────────────────────────────────────
        const parts = [];
        if (steps > 0)        parts.push(`${steps.toLocaleString()} steps`);
        if (totalSleepMs > 0) parts.push(`${toHours(totalSleepMs)}h sleep`);
        if (deepSleepMs > 0)  parts.push(`${toHours(deepSleepMs)}h deep`);

        setStatus(
          parts.length > 0
            ? `Filled: ${parts.join(" · ")}`
            : "No data found for this date.",
          parts.length > 0 ? "text-emerald-600" : "text-amber-600"
        );

      } catch (err) {
        console.error(err);
        setStatus("Fetch failed — check the browser console.", "text-red-600");
      } finally {
        updateFetchBtn();
      }
    });
  </script>

  <script>
    import { supabase } from "../../utils/supabase";

    function formToDataRow() {
      const dateEl         = document.getElementById("date");
      const totalSleepEl   = document.getElementById("totalSleep");
      const deepSleepEl    = document.getElementById("deepSleep");
      const sleepQualityEl = document.getElementById("sleepQuality");
      const stepsEl        = document.getElementById("steps");
      const screenTimeEl   = document.getElementById("screenTime");
      const lastPhoneEl    = document.getElementById("lastPhoneUse");

      const date           = dateEl instanceof HTMLInputElement ? dateEl.value.trim() : "";
      const totalSleepRaw  = totalSleepEl instanceof HTMLInputElement ? totalSleepEl.value : "";
      const deepSleepRaw   = deepSleepEl instanceof HTMLInputElement ? deepSleepEl.value : "";
      const sleepQuality   = sleepQualityEl instanceof HTMLSelectElement ? sleepQualityEl.value.trim() : "";
      const stepsRaw       = stepsEl instanceof HTMLInputElement ? stepsEl.value : "";
      const screenTimeRaw  = screenTimeEl instanceof HTMLInputElement ? screenTimeEl.value : "";
      const lastPhoneUse   = lastPhoneEl instanceof HTMLInputElement ? lastPhoneEl.value.trim() : "";

      const hoursToMinutesOrNull = (raw = "") => {
        if (raw === "") return null;
        const n = Number(raw);
        return Number.isFinite(n) ? Math.round(n * 60) : null;
      };
      const stepsOrNull = (raw = "") => {
        if (raw === "") return null;
        const n = Number(raw);
        return Number.isFinite(n) ? Math.round(n) : null;
      };
      const strOrNull      = (s = "") => s === "" ? null : s;

      return {
        date:            date || null,
        Total_sleep:     hoursToMinutesOrNull(totalSleepRaw),
        Deep_sleep:      hoursToMinutesOrNull(deepSleepRaw),
        Sleep_quality:   strOrNull(sleepQuality),
        Steps:           stepsOrNull(stepsRaw),
        Screen:          hoursToMinutesOrNull(screenTimeRaw),
        Last_phone_time: strOrNull(lastPhoneUse),
      };
    }

    const form    = document.getElementById("day-entry-form");
    const message = document.getElementById("save-message");

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!(form instanceof HTMLFormElement) || !(message instanceof HTMLParagraphElement)) return;

      const row = formToDataRow();
      if (!row.date) {
        message.className = "text-center font-medium text-red-600";
        message.textContent = "Please choose a date.";
        return;
      }

      message.className = "text-center font-medium text-slate-600";
      message.textContent = "Saving…";

      const { data: existing, error: checkError } = await supabase
        .from("Data").select("id").eq("date", row.date).limit(1);

      if (checkError) {
        message.className = "text-center font-medium text-red-600";
        message.textContent = checkError.message || "Could not verify this date.";
        return;
      }

      if (existing && existing.length > 0) {
        message.className = "text-center font-medium text-red-600";
        message.textContent = "You already have an entry for this date.";
        return;
      }

      const { error } = await supabase.from("Data").insert([row]);

      if (error) {
        message.className = "text-center font-medium text-red-600";
        message.textContent = error.code === "23505"
          ? "An entry for this date already exists."
          : error.message || "Could not save.";
        return;
      }

      message.className = "text-center font-medium text-emerald-600";
      message.textContent = "Entry saved successfully";
      form.reset();
      setTimeout(() => { window.location.href = "/visualisations_new"; }, 700);
    });
  </script>
</Layout>