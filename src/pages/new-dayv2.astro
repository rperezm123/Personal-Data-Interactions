---
import Layout from '../layouts/Layout.astro';
import "../styles/global.css";
---

<Layout>
<section style="min-height:100dvh; padding: 2.5rem 1.5rem; background: #0c0f14; font-family: 'DM Sans', sans-serif;">

  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap');

    :root {
      --font-display: 'DM Serif Display', serif;
      --font-body: 'DM Sans', sans-serif;
      --text-xs: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
      --text-sm: clamp(0.875rem, 0.8rem + 0.35vw, 1rem);
      --text-base: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
      --text-lg: clamp(1.125rem, 1rem + 0.75vw, 1.5rem);
      --space-1:.25rem; --space-2:.5rem; --space-3:.75rem;
      --space-4:1rem;   --space-5:1.25rem; --space-6:1.5rem;
      --space-8:2rem;   --space-10:2.5rem;
      --color-bg:#0c0f14; --color-surface:#141920; --color-surface-2:#1c2330;
      --color-border:rgba(255,255,255,0.07); --color-divider:rgba(255,255,255,0.07);
      --color-text:#e8edf5; --color-text-muted:#6b7a99; --color-text-faint:#6b7a99;
      --color-primary:#4f8eff; --color-primary-hover:rgba(79,142,255,0.8);
      --color-primary-highlight:rgba(79,142,255,0.1);
      --color-accent:#a78bfa;
      --color-star:#f5a623; --color-star-empty:rgba(255,255,255,0.07);
      --color-success:#2dca8a;
      --radius-lg:.75rem; --radius-xl:1rem; --radius-2xl:1.5rem; --radius-full:9999px;
      --shadow-sm:0 1px 3px rgba(0,0,0,.2);
      --shadow-md:0 4px 16px rgba(0,0,0,.3);
      --transition:180ms cubic-bezier(.16,1,.3,1);
    }

    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    input,button,textarea,select{font:inherit;color:inherit}
    button{cursor:pointer;background:none;border:none}
    :focus-visible{outline:2px solid var(--color-primary);outline-offset:3px;border-radius:.375rem}

    .v2-container{max-width:1000px;margin-inline:auto;display:flex;flex-direction:column;gap:var(--space-8)}
    .v2-hero{text-align:center}
    .v2-eyebrow{
      display:inline-flex;align-items:center;gap:var(--space-2);
      font-size:var(--text-xs);font-weight:600;letter-spacing:.15em;text-transform:uppercase;
      color:var(--color-primary);background:var(--color-primary-highlight);
      padding:var(--space-1) var(--space-3);border-radius:var(--radius-full);margin-bottom:var(--space-4)
    }
    .v2-eyebrow svg{width:14px;height:14px}
    .v2-hero h1{
      font-family:var(--font-display);font-size:clamp(2rem,1.2rem + 2.5vw,3rem);
      font-weight:400;line-height:1.15;color:var(--color-text);margin-bottom:var(--space-3)
    }
    .v2-hero h1 em{font-style:italic;color:var(--color-accent)}
    .v2-hero p{font-size:var(--text-base);color:var(--color-text-muted);max-width:52ch;margin-inline:auto}

    .v2-progress{display:flex;align-items:center;gap:var(--space-3)}
    .v2-progress-track{flex:1;height:4px;background:var(--color-border);border-radius:var(--radius-full);overflow:hidden}
    .v2-progress-fill{
      height:100%;border-radius:var(--radius-full);
      background:linear-gradient(90deg,var(--color-primary),var(--color-accent));
      width:0%;transition:width .5s cubic-bezier(.16,1,.3,1)
    }
    .v2-progress-label{font-size:var(--text-xs);color:var(--color-text-muted);white-space:nowrap}

    .v2-card{
      background:var(--color-surface);border:1px solid var(--color-border);
      border-radius:var(--radius-2xl);padding:var(--space-6) var(--space-8);
      box-shadow:var(--shadow-sm);transition:box-shadow var(--transition)
    }
    .v2-card:focus-within{box-shadow:var(--shadow-md)}
    .v2-card-header{
      display:flex;align-items:center;gap:var(--space-3);
      margin-bottom:var(--space-6);padding-bottom:var(--space-4);
      border-bottom:1px solid var(--color-divider)
    }
    .v2-card-icon{
      width:38px;height:38px;border-radius:var(--radius-lg);
      background:var(--color-primary-highlight);
      display:flex;align-items:center;justify-content:center;
      flex-shrink:0;color:var(--color-primary)
    }
    .v2-card-icon svg{width:20px;height:20px}
    .v2-card-title{font-size:var(--text-lg);font-weight:700;color:var(--color-text)}
    .v2-card-subtitle{font-size:var(--text-xs);color:var(--color-text-muted);margin-top:2px}

    .v2-form-grid{display:grid;gap:var(--space-6)}
    .v2-form-grid-2{grid-template-columns:1fr 1fr}
    .v2-field{display:flex;flex-direction:column;gap:var(--space-2)}
    .v2-field-full{grid-column:1/-1}
    .v2-label{font-size:var(--text-sm);font-weight:600;color:var(--color-text)}
    .v2-label-hint{font-weight:400;color:var(--color-text-muted);font-size:var(--text-xs);margin-left:var(--space-2)}
    .v2-input{
      width:100%;border:1.5px solid var(--color-border);border-radius:var(--radius-lg);
      padding:var(--space-3) var(--space-4);font-size:var(--text-sm);
      background:var(--color-surface-2);color:var(--color-text);
      transition:border-color var(--transition),box-shadow var(--transition),background var(--transition)
    }
    .v2-input:hover{border-color:color-mix(in oklab,var(--color-primary) 40%,var(--color-border))}
    .v2-input:focus{
      outline:none;border-color:var(--color-primary);background:var(--color-surface);
      box-shadow:0 0 0 3px color-mix(in oklab,var(--color-primary) 15%,transparent)
    }
    .v2-input::placeholder{color:var(--color-text-faint)}
    textarea.v2-input{resize:vertical;min-height:100px;line-height:1.7}

    .v2-slider-wrap{display:flex;flex-direction:column;gap:var(--space-3)}
    .v2-slider-header{display:flex;justify-content:space-between;align-items:center}
    .v2-slider-value{
      font-size:var(--text-base);font-weight:700;color:var(--color-primary);
      background:var(--color-primary-highlight);padding:2px var(--space-3);
      border-radius:var(--radius-full);min-width:56px;text-align:center
    }
    .v2-slider-track-wrap{padding-block:var(--space-2)}
    input[type="range"].v2-range{
      -webkit-appearance:none;appearance:none;width:100%;height:6px;
      border-radius:var(--radius-full);background:var(--color-border);cursor:pointer;
      background-image:linear-gradient(var(--color-primary),var(--color-primary));
      background-size:var(--fill,0%) 100%;background-repeat:no-repeat;
      transition:background-size var(--transition)
    }
    input[type="range"].v2-range::-webkit-slider-thumb{
      -webkit-appearance:none;width:22px;height:22px;border-radius:50%;
      background:var(--color-surface);border:2.5px solid var(--color-primary);
      box-shadow:0 2px 8px rgba(79,98,232,.25);
      transition:box-shadow var(--transition),transform var(--transition)
    }
    input[type="range"].v2-range::-moz-range-thumb{
      width:22px;height:22px;border-radius:50%;background:var(--color-surface);
      border:2.5px solid var(--color-primary);box-shadow:0 2px 8px rgba(79,98,232,.25)
    }
    input[type="range"].v2-range:hover::-webkit-slider-thumb{box-shadow:0 3px 12px rgba(79,98,232,.35);transform:scale(1.1)}
    input[type="range"].v2-range:focus{outline:none}
    .v2-slider-marks{display:flex;justify-content:space-between;margin-top:var(--space-1)}
    .v2-slider-mark{font-size:var(--text-xs);color:var(--color-text-faint)}

    .v2-star-row{display:flex;align-items:center;gap:var(--space-3)}
    .v2-stars{display:flex;gap:var(--space-2)}
    .v2-star{
      font-size:1.75rem;color:var(--color-star-empty);cursor:pointer;
      transition:color var(--transition),transform var(--transition);
      line-height:1;user-select:none
    }
    .v2-star.active{color:var(--color-star)}
    .v2-star:hover{transform:scale(1.2)}
    .v2-star-label{font-size:var(--text-sm);font-weight:600;color:var(--color-text-muted);min-width:70px}
    .v2-star-label.has-value{color:var(--color-primary)}

    .v2-pill-group{display:flex;gap:var(--space-2)}
    .v2-pill{
      flex:1;padding:var(--space-2) var(--space-4);border-radius:var(--radius-full);
      border:1.5px solid var(--color-border);font-size:var(--text-sm);font-weight:600;
      color:var(--color-text-muted);background:var(--color-surface-2);text-align:center;
      transition:all var(--transition)
    }
    .v2-pill:hover{border-color:var(--color-primary);color:var(--color-primary)}
    .v2-pill.selected{background:var(--color-primary);border-color:var(--color-primary);color:#fff}
    .v2-pill.selected-no{background:var(--color-success);border-color:var(--color-success);color:#fff}

    .v2-actions{display:flex;flex-wrap:wrap;gap:var(--space-4);justify-content:center;padding-top:var(--space-4)}
    .v2-btn{
      display:inline-flex;align-items:center;gap:var(--space-2);
      padding:var(--space-3) var(--space-8);border-radius:var(--radius-full);
      font-size:var(--text-sm);font-weight:600;transition:all var(--transition);text-decoration:none
    }
    .v2-btn-primary{
      background:var(--color-primary);color:#fff;
      box-shadow:0 4px 16px color-mix(in oklab,var(--color-primary) 40%,transparent)
    }
    .v2-btn-primary:hover{
      background:var(--color-primary-hover);
      box-shadow:0 6px 20px color-mix(in oklab,var(--color-primary) 50%,transparent);
      transform:translateY(-1px)
    }
    .v2-btn-ghost{background:transparent;color:var(--color-text-muted);border:1.5px solid var(--color-border)}
    .v2-btn-ghost:hover{border-color:var(--color-primary);color:var(--color-primary)}

    .v2-save-message{
      text-align:center;font-size:var(--text-sm);font-weight:600;
      color:var(--color-success);min-height:1.5em;opacity:0;transition:opacity var(--transition)
    }
    .v2-save-message.visible{opacity:1}

    @media(max-width:600px){
      .v2-card{padding:var(--space-5)}
      .v2-form-grid-2{grid-template-columns:1fr}
    }
  </style>

  <div class="v2-container">
    <header class="v2-hero">
      <div class="v2-eyebrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"/><path d="M12 6v6l4 2"/>
        </svg>
        Daily Entry
      </div>
      <h1>How did you <em>sleep</em> &amp; live today?</h1>
      <p>Log your sleep and habits — uncover what shapes your deep rest.</p>
    </header>

    <div class="v2-progress" aria-label="Form progress">
      <div class="v2-progress-track">
        <div class="v2-progress-fill" id="v2-progress-fill"></div>
      </div>
      <span class="v2-progress-label" id="v2-progress-label">0 / 9 fields</span>
    </div>

    <form id="v2-day-entry-form">
      <!-- Sleep data -->
      <div class="v2-card" style="margin-bottom:2rem">
        <div class="v2-card-header">
          <div class="v2-card-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
          </div>
          <div>
            <div class="v2-card-title">Sleep data</div>
            <div class="v2-card-subtitle">When and how long did you sleep?</div>
          </div>
        </div>
        <div class="v2-form-grid v2-form-grid-2">
          <div class="v2-field">
            <label class="v2-label" for="v2-date">Date</label>
            <input id="v2-date" name="date" type="date" class="v2-input" />
          </div>
          <div></div>
          <div class="v2-field v2-field-full">
            <div class="v2-slider-wrap">
              <div class="v2-slider-header">
                <label class="v2-label" for="v2-totalSleep">
                  Total Sleep <span class="v2-label-hint">hours</span>
                </label>
                <span class="v2-slider-value" id="v2-totalSleepDisplay">7.5</span>
              </div>
              <div class="v2-slider-track-wrap">
                <input type="range" id="v2-totalSleep" name="totalSleep" class="v2-range"
                  min="0" max="12" step="0.5" value="7.5" aria-label="Total sleep hours" />
              </div>
              <div class="v2-slider-marks">
                <span class="v2-slider-mark">0 h</span><span class="v2-slider-mark">3 h</span>
                <span class="v2-slider-mark">6 h</span><span class="v2-slider-mark">9 h</span>
                <span class="v2-slider-mark">12 h</span>
              </div>
            </div>
          </div>
          <div class="v2-field v2-field-full">
            <div class="v2-slider-wrap">
              <div class="v2-slider-header">
                <label class="v2-label" for="v2-deepSleep">
                  Deep Sleep <span class="v2-label-hint">hours</span>
                </label>
                <span class="v2-slider-value" id="v2-deepSleepDisplay">1.5</span>
              </div>
              <div class="v2-slider-track-wrap">
                <input type="range" id="v2-deepSleep" name="deepSleep" class="v2-range"
                  min="0" max="6" step="0.1" value="1.5" aria-label="Deep sleep hours" />
              </div>
              <div class="v2-slider-marks">
                <span class="v2-slider-mark">0 h</span><span class="v2-slider-mark">1.5 h</span>
                <span class="v2-slider-mark">3 h</span><span class="v2-slider-mark">4.5 h</span>
                <span class="v2-slider-mark">6 h</span>
              </div>
            </div>
          </div>
          <div class="v2-field v2-field-full">
            <label class="v2-label">Sleep Quality</label>
            <div class="v2-star-row">
              <div class="v2-stars" role="radiogroup" aria-label="Sleep quality rating" id="v2-star-group">
                <span class="v2-star" role="radio" aria-checked="false" aria-label="1 — Very poor" tabindex="0">★</span>
                <span class="v2-star" role="radio" aria-checked="false" aria-label="2 — Poor" tabindex="0">★</span>
                <span class="v2-star" role="radio" aria-checked="false" aria-label="3 — Okay" tabindex="0">★</span>
                <span class="v2-star" role="radio" aria-checked="false" aria-label="4 — Good" tabindex="0">★</span>
                <span class="v2-star" role="radio" aria-checked="false" aria-label="5 — Excellent" tabindex="0">★</span>
              </div>
              <span class="v2-star-label" id="v2-star-label">Not rated</span>
            </div>
            <input type="hidden" id="v2-sleepQuality" name="sleepQuality" value="" />
          </div>
        </div>
      </div>

      <!-- Daily habits -->
      <div class="v2-card" style="margin-bottom:2rem">
        <div class="v2-card-header">
          <div class="v2-card-icon" aria-hidden="true" style="background:#edf7f0;color:var(--color-success)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <div>
            <div class="v2-card-title">Daily habits</div>
            <div class="v2-card-subtitle">Your activity and lifestyle today</div>
          </div>
        </div>
        <div class="v2-form-grid v2-form-grid-2">
          <div class="v2-field">
            <label class="v2-label">Caffeine after 3 PM</label>
            <div class="v2-pill-group" role="group" aria-label="Caffeine after 3 PM">
              <button type="button" class="v2-pill" data-group="caffeine" data-value="No" aria-pressed="false">☕ No</button>
              <button type="button" class="v2-pill" data-group="caffeine" data-value="Yes" aria-pressed="false">✓ Yes</button>
            </div>
            <input type="hidden" id="v2-caffeineAfter3" name="caffeineAfter3" value="" />
          </div>
          <div class="v2-field">
            <label class="v2-label" for="v2-lastPhoneUse">
              Last Phone Use <span class="v2-label-hint">time</span>
            </label>
            <input id="v2-lastPhoneUse" name="lastPhoneUse" type="time" class="v2-input" />
          </div>
          <div class="v2-field v2-field-full">
            <div class="v2-slider-wrap">
              <div class="v2-slider-header">
                <label class="v2-label" for="v2-steps">Daily Steps</label>
                <span class="v2-slider-value" id="v2-stepsDisplay">8,000</span>
              </div>
              <div class="v2-slider-track-wrap">
                <input type="range" id="v2-steps" name="steps" class="v2-range"
                  min="0" max="30000" step="500" value="8000" aria-label="Daily steps" />
              </div>
              <div class="v2-slider-marks">
                <span class="v2-slider-mark">0</span><span class="v2-slider-mark">7.5k</span>
                <span class="v2-slider-mark">15k</span><span class="v2-slider-mark">22.5k</span>
                <span class="v2-slider-mark">30k</span>
              </div>
            </div>
          </div>
          <div class="v2-field v2-field-full">
            <div class="v2-slider-wrap">
              <div class="v2-slider-header">
                <label class="v2-label" for="v2-screenTime">
                  Screen Time <span class="v2-label-hint">hours</span>
                </label>
                <span class="v2-slider-value" id="v2-screenTimeDisplay">4.0</span>
              </div>
              <div class="v2-slider-track-wrap">
                <input type="range" id="v2-screenTime" name="screenTime" class="v2-range"
                  min="0" max="16" step="0.5" value="4" aria-label="Screen time hours" />
              </div>
              <div class="v2-slider-marks">
                <span class="v2-slider-mark">0 h</span><span class="v2-slider-mark">4 h</span>
                <span class="v2-slider-mark">8 h</span><span class="v2-slider-mark">12 h</span>
                <span class="v2-slider-mark">16 h</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Reflection -->
      <div class="v2-card" style="margin-bottom:2rem">
        <div class="v2-card-header">
          <div class="v2-card-icon" aria-hidden="true" style="background:#f3effe;color:var(--color-accent)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <div>
            <div class="v2-card-title">Reflection</div>
            <div class="v2-card-subtitle">Anything notable about today?</div>
          </div>
        </div>
        <div class="v2-form-grid">
          <div class="v2-field">
            <label class="v2-label" for="v2-notes">Notes <span class="v2-label-hint">optional</span></label>
            <textarea id="v2-notes" name="notes" class="v2-input"
              placeholder="Add anything important about your day or sleep."></textarea>
          </div>
        </div>
      </div>

      <div class="v2-actions">
        <button type="submit" class="v2-btn v2-btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          Save Entry
        </button>
        <a href="/dashboard" class="v2-btn v2-btn-ghost">← Back to Dashboard</a>
      </div>
      <p class="v2-save-message" id="v2-save-message" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  function initSlider(id: string, displayId: string, fmt?: (v: number) => string) {
    const r = document.getElementById(id) as HTMLInputElement | null;
    const d = document.getElementById(displayId);
    if (!r || !d) return;
    const update = () => {
      const v = parseFloat(r.value);
      d.textContent = fmt ? fmt(v) : v.toString();
      const pct = ((v - parseFloat(r.min)) / (parseFloat(r.max) - parseFloat(r.min))) * 100;
      r.style.setProperty('--fill', pct + '%');
    };
    r.addEventListener('input', update);
    update();
  }
  initSlider('v2-totalSleep',  'v2-totalSleepDisplay',  v => v.toFixed(1));
  initSlider('v2-deepSleep',   'v2-deepSleepDisplay',   v => v.toFixed(1));
  initSlider('v2-steps',       'v2-stepsDisplay',       v => v >= 1000 ? (v/1000).toFixed(1).replace('.0','')+'k' : String(v));
  initSlider('v2-screenTime',  'v2-screenTimeDisplay',  v => v.toFixed(1));

  const starLabels   = ['','Very poor','Poor','Okay','Good','Excellent'];
  const qualityVals  = ['','poor','poor','fair','good','excellent'];
  const stars        = document.querySelectorAll('.v2-star');
  const starLabelEl  = document.getElementById('v2-star-label');
  const qualityInput = document.getElementById('v2-sleepQuality') as HTMLInputElement | null;
  let rating = 0;

  function setStars(n: number) {
    stars.forEach((s, i) => {
      s.classList.toggle('active', i < n);
      s.setAttribute('aria-checked', i < n ? 'true' : 'false');
    });
    if (starLabelEl) {
      starLabelEl.textContent = n ? starLabels[n] : 'Not rated';
      starLabelEl.classList.toggle('has-value', n > 0);
    }
    if (qualityInput) qualityInput.value = qualityVals[n] || '';
    rating = n;
    updateProgress();
  }
  stars.forEach((s, i) => {
    s.addEventListener('click', () => setStars(i + 1));
    s.addEventListener('mouseenter', () => stars.forEach((x, j) => x.classList.toggle('active', j <= i)));
    s.addEventListener('keydown', (e: Event) => {
      const k = (e as KeyboardEvent).key;
      if (k === 'Enter' || k === ' ') { e.preventDefault(); setStars(i + 1); }
      if (k === 'ArrowRight' && i < 4) (stars[i + 1] as HTMLElement).focus();
      if (k === 'ArrowLeft'  && i > 0) (stars[i - 1] as HTMLElement).focus();
    });
  });
  document.getElementById('v2-star-group')?.addEventListener('mouseleave',
    () => stars.forEach((s, i) => s.classList.toggle('active', i < rating)));

  document.querySelectorAll('[data-group]').forEach(btn => {
    btn.addEventListener('click', () => {
      const g = (btn as HTMLElement).dataset.group;
      const v = (btn as HTMLElement).dataset.value;
      document.querySelectorAll(`[data-group="${g}"]`).forEach(b => {
        b.classList.remove('selected','selected-no');
        b.setAttribute('aria-pressed','false');
      });
      btn.classList.add(v === 'No' ? 'selected-no' : 'selected');
      btn.setAttribute('aria-pressed','true');
      const h = document.getElementById('v2-caffeineAfter3') as HTMLInputElement | null;
      if (h) h.value = v ?? '';
      updateProgress();
    });
  });

  const tracked = ['v2-date','v2-totalSleep','v2-deepSleep','v2-sleepQuality',
                   'v2-caffeineAfter3','v2-steps','v2-screenTime','v2-lastPhoneUse','v2-notes'];
  function updateProgress() {
    const filled = tracked.filter(id => (document.getElementById(id) as HTMLInputElement)?.value).length;
    const fill  = document.getElementById('v2-progress-fill');
    const label = document.getElementById('v2-progress-label');
    if (fill)  fill.style.width  = Math.round((filled / tracked.length) * 100) + '%';
    if (label) label.textContent = `${filled} / ${tracked.length} fields`;
  }
  document.querySelectorAll('.v2-input,.v2-range').forEach(el => {
    el.addEventListener('input',  updateProgress);
    el.addEventListener('change', updateProgress);
  });
  updateProgress();

  const form = document.getElementById('v2-day-entry-form') as HTMLFormElement | null;
  const msg  = document.getElementById('v2-save-message') as HTMLElement | null;
  form?.addEventListener('submit', e => {
    e.preventDefault();
    const g = (id: string) => document.getElementById(id) as HTMLInputElement;
    const entry = {
      date:           g('v2-date').value,
      totalSleep:     parseFloat(g('v2-totalSleep').value),
      deepSleep:      parseFloat(g('v2-deepSleep').value),
      sleepQuality:   g('v2-sleepQuality').value,
      caffeineAfter3: g('v2-caffeineAfter3').value,
      steps:          parseInt(g('v2-steps').value),
      screenTime:     parseFloat(g('v2-screenTime').value),
      lastPhoneUse:   g('v2-lastPhoneUse').value,
      notes:          (document.getElementById('v2-notes') as HTMLTextAreaElement).value,
    };
    const entries = JSON.parse(localStorage.getItem('sleepEntries') || '[]');
    entries.push(entry);
    localStorage.setItem('sleepEntries', JSON.stringify(entries));
    if (msg) { msg.textContent = '✓ Entry saved — heading to your visualisations…'; msg.classList.add('visible'); }
    form.reset();
    setStars(0);
    setTimeout(() => { window.location.href = '/visualisations'; }, 700);
  });
</script>
</Layout>
