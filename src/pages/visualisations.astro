---
import Layout from '../layouts/Layout.astro';
import MyButton from '../components/button.jsx';
import "../styles/global.css";
---

<Layout>
  <section class="min-h-screen bg-slate-50 px-6 py-10">
    <div class="mx-auto flex max-w-7xl flex-col gap-8">
      
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">
          Visualisations
        </p>
        <h1 class="mt-2 text-4xl font-extrabold text-slate-900 md:text-6xl">
          Explore your sleep and habit patterns
        </h1>
        <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-600">
          Compare deep sleep with caffeine, screen time, activity, and other daily behaviors to find meaningful patterns.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="/dashboard">
          <MyButton name="Back to Dashboard" />
        </a>
        <a href="/new-day">
          <MyButton name="Add New Day" />
        </a>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-2xl font-bold text-slate-900">Sleep Trends Over Time</h2>
            <div id="loading-indicator" class="w-3 h-3 bg-sky-500 rounded-full animate-pulse"></div>
          </div>
          <p class="mb-5 text-slate-600">
            Track your total sleep and deep sleep patterns across recent days to identify trends and improvements.
          </p>
          <div id="sleep-chart" class="transition-transform duration-300 hover:scale-[1.02]">
            <div id="no-data-message" class="hidden text-center py-12 text-slate-500">
              <p class="text-lg font-medium">No sleep data available yet</p>
              <p class="text-sm mt-2">Start by adding your first day entry to see your sleep trends!</p>
            </div>
          </div>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-2xl font-bold text-slate-900">Habits vs Sleep Quality</h2>
            <div id="loading-habits" class="w-3 h-3 bg-purple-500 rounded-full animate-pulse"></div>
          </div>
          <p class="mb-5 text-slate-600">
            See how your daily habits (caffeine, steps, screen time) correlate with your deep sleep duration.
          </p>
          <div id="habits-chart" class="transition-transform duration-300 hover:scale-[1.02]">
            <div id="no-habits-message" class="hidden text-center py-12 text-slate-500">
              <p class="text-lg font-medium">No habit data available yet</p>
              <p class="text-sm mt-2">Add more daily entries to see habit correlations!</p>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-2xl font-bold text-slate-900">Weekly Habit Patterns</h2>
          <div id="loading-patterns" class="w-3 h-3 bg-amber-500 rounded-full animate-pulse"></div>
        </div>
        <p class="mb-5 text-slate-600">
          Discover your weekly patterns in caffeine consumption, activity levels, and screen time usage.
        </p>
        <div id="patterns-chart" class="transition-transform duration-300 hover:scale-[1.02]">
          <div id="no-patterns-message" class="hidden text-center py-12 text-slate-500">
            <p class="text-lg font-medium">No pattern data available yet</p>
            <p class="text-sm mt-2">Track your habits for a full week to see patterns!</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script type="module">
    import * as Plot from "https://cdn.jsdelivr.net/npm/@observablehq/plot@0.6/+esm";
    import { supabase } from "../../utils/supabase";

    // Fetch real sleep and habit data from Supabase
    async function fetchSleepData() {
      try {
        const { data: rawData, error } = await supabase
          .from("Data")
          .select("*")
          .order("date", { ascending: true })
          .limit(30); // Get last 30 days

        if (error) {
          console.error("Error fetching data:", error);
          return [];
        }

        return rawData.map(row => ({
          date: new Date(row.date), // Parse as Date object
          formattedDate: new Date(row.date).toLocaleDateString('en-US', { 
            month: 'short', 
            day: 'numeric' 
          }),
          dayOfWeek: new Date(row.date).toLocaleDateString('en-US', { weekday: 'short' }),
          totalSleep: row.Total_sleep != null ? Number(row.Total_sleep) / 60 : 0, // Convert minutes to hours
          deepSleep: row.Deep_sleep != null ? Number(row.Deep_sleep) / 60 : 0, // Convert minutes to hours
          caffeineAfter3: row.Caffeine === 1 ? "Yes" : (row.Caffeine === 0 ? "No" : "Unknown"),
          steps: row.Steps != null ? Number(row.Steps) : 0,
          screenTime: row.Screen != null ? Number(row.Screen) / 60 : 0, // Convert minutes to hours
          phoneTime: row.Last_phone_time || "Unknown",
          sleepQuality: row.Sleep_quality || "Unknown"
        }));
      } catch (error) {
        console.error("Error in fetchSleepData:", error);
        return [];
      }
    }

    // Create line chart with sleep data
    function createSleepChart(data) {
      if (!data || data.length === 0) {
        document.querySelector("#no-data-message")?.classList.remove('hidden');
        document.querySelector("#loading-indicator")?.classList.add('hidden');
        return;
      }

      // Hide loading and no-data messages
      document.querySelector("#loading-indicator")?.classList.add('hidden');
      document.querySelector("#no-data-message")?.classList.add('hidden');

      // Prepare data for plotting (both total sleep and deep sleep)
      const totalSleepData = data.map(d => ({
        x: d.date,
        y: d.totalSleep,
        date: d.formattedDate,
        type: "Total Sleep"
      }));

      const deepSleepData = data.map(d => ({
        x: d.date,
        y: d.deepSleep,
        date: d.formattedDate,
        type: "Deep Sleep"
      }));

      const chartData = [...totalSleepData, ...deepSleepData];

      const chart = Plot.plot({
        width: Math.min(window.innerWidth - 100, 1000),
        height: 400,
        style: {
          background: "white",
          color: "#0f172a",
          fontSize: "14px"
        },
        marginLeft: 60,
        marginRight: 30,
        marginTop: 20,
        marginBottom: 60,
        x: {
          type: "time",
          label: "Date",
          tickRotate: -45,
          ticks: data.length > 10 ? Math.ceil(data.length / 5) : data.length
        },
        y: {
          grid: true,
          label: "Hours",
          domain: [0, Math.max(...data.map(d => Math.max(d.totalSleep, d.deepSleep))) + 1]
        },
        color: {
          legend: true,
          domain: ["Total Sleep", "Deep Sleep"],
          range: ["#3b82f6", "#10b981"]
        },
        marks: [
          // Total sleep line
          Plot.line(totalSleepData, {
            x: "x",
            y: "y",
            stroke: "#3b82f6",
            strokeWidth: 3,
            tip: true,
            title: (d) => `${d.date}: Total Sleep ${d.y.toFixed(1)}h`
          }),
          // Deep sleep line
          Plot.line(deepSleepData, {
            x: "x",
            y: "y",
            stroke: "#10b981",
            strokeWidth: 3,
            tip: true,
            title: (d) => `${d.date}: Deep Sleep ${d.y.toFixed(1)}h`
          }),
          // Total sleep dots
          Plot.dot(totalSleepData, {
            x: "x",
            y: "y",
            fill: "#3b82f6",
            r: 4,
            stroke: "white",
            strokeWidth: 2,
            tip: true,
            title: (d) => `${d.date}: Total Sleep ${d.y.toFixed(1)}h`
          }),
          // Deep sleep dots
          Plot.dot(deepSleepData, {
            x: "x",
            y: "y",
            fill: "#10b981",
            r: 4,
            stroke: "white",
            strokeWidth: 2,
            tip: true,
            title: (d) => `${d.date}: Deep Sleep ${d.y.toFixed(1)}h`
          }),
          // Zero line
          Plot.ruleY([0])
        ]
      });

      document.querySelector("#sleep-chart")?.append(chart);
    }

    // Create habit correlation chart
    function createHabitsChart(data) {
      if (!data || data.length === 0) {
        document.querySelector("#no-habits-message")?.classList.remove('hidden');
        document.querySelector("#loading-habits")?.classList.add('hidden');
        return;
      }

      document.querySelector("#loading-habits")?.classList.add('hidden');
      document.querySelector("#no-habits-message")?.classList.add('hidden');

      // Filter data for valid entries
      const validData = data.filter(d => d.deepSleep > 0);
      
      if (validData.length === 0) {
        document.querySelector("#no-habits-message")?.classList.remove('hidden');
        return;
      }

      // Prepare data for different habit correlations
      const caffeineData = validData
        .filter(d => d.caffeineAfter3 !== "Unknown")
        .map(d => ({
          x: d.caffeineAfter3 === "Yes" ? 1 : 2,
          y: d.deepSleep,
          type: "caffeine",
          date: d.formattedDate,
          details: `${d.caffeineAfter3} caffeine, ${d.deepSleep.toFixed(1)}h deep sleep`
        }));

      const stepsData = validData
        .filter(d => d.steps > 0)
        .map(d => ({
          x: 3 + (d.steps / 10000), // Normalize steps
          y: d.deepSleep,
          type: "steps",
          date: d.formattedDate,
          details: `${d.steps.toLocaleString()} steps, ${d.deepSleep.toFixed(1)}h deep sleep`
        }));

      const screenData = validData
        .filter(d => d.screenTime > 0)
        .map(d => ({
          x: 5 - (d.screenTime / 8), // Inverse: less screen time = better position
          y: d.deepSleep,
          type: "screen",
          date: d.formattedDate,
          details: `${d.screenTime.toFixed(1)}h screen time, ${d.deepSleep.toFixed(1)}h deep sleep`
        }));

      const allHabitData = [...caffeineData, ...stepsData, ...screenData];

      if (allHabitData.length === 0) {
        document.querySelector("#no-habits-message")?.classList.remove('hidden');
        return;
      }

      const chart = Plot.plot({
        width: Math.min(window.innerWidth - 100, 500),
        height: 400,
        style: {
          background: "white",
          color: "#0f172a",
          fontSize: "14px"
        },
        marginLeft: 60,
        marginRight: 30,
        marginBottom: 60,
        marginTop: 20,
        y: {
          grid: true,
          label: "Deep Sleep (hours)",
          domain: [0, Math.max(...validData.map(d => d.deepSleep)) + 0.5]
        },
        x: {
          label: "",
          domain: [0.5, 5.5],
          ticks: [1, 2, 3, 4, 5],
          tickFormat: d => {
            const labels = {1: "Caf Yes", 2: "Caf No", 3: "Steps", 4: "Screen", 5: "Low Screen"};
            return labels[d] || "";
          }
        },
        marks: [
          Plot.dot(allHabitData, {
            x: "x",
            y: "y",
            fill: (d) => d.type === "caffeine" ? "#f59e0b" : d.type === "steps" ? "#10b981" : "#ef4444",
            r: 6,
            tip: true,
            title: (d) => `${d.date}: ${d.details}`
          }),
          Plot.ruleY([0])
        ]
      });

      document.querySelector("#habits-chart")?.append(chart);
    }

    // Create weekly patterns chart
    function createPatternsChart(data) {
      if (!data || data.length === 0) {
        document.querySelector("#no-patterns-message")?.classList.remove('hidden');
        document.querySelector("#loading-patterns")?.classList.add('hidden');
        return;
      }

      document.querySelector("#loading-patterns")?.classList.add('hidden');
      document.querySelector("#no-patterns-message")?.classList.add('hidden');

      const daysOfWeek = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
      
      // Calculate averages for each day
      const patternsData = [];
      daysOfWeek.forEach(day => {
        const dayData = data.filter(d => d.dayOfWeek === day);
        if (dayData.length > 0) {
          patternsData.push({
            day: day,
            caffeineRate: dayData.filter(d => d.caffeineAfter3 === "Yes").length / dayData.length,
            avgSteps: dayData.reduce((sum, d) => sum + d.steps, 0) / dayData.length,
            avgScreenTime: dayData.reduce((sum, d) => sum + d.screenTime, 0) / dayData.length,
            avgDeepSleep: dayData.reduce((sum, d) => sum + d.deepSleep, 0) / dayData.length
          });
        }
      });

      if (patternsData.length === 0) {
        document.querySelector("#no-patterns-message")?.classList.remove('hidden');
        return;
      }

      // Prepare data for each metric
      const caffeineLineData = patternsData.map(d => ({
        x: d.day,
        y: d.caffeineRate,
        metric: "Caffeine Rate",
        value: `${(d.caffeineRate * 100).toFixed(0)}%`
      }));

      const stepsLineData = patternsData.map(d => ({
        x: d.day,
        y: d.avgSteps / 1000, // Convert to thousands
        metric: "Steps",
        value: `${d.avgSteps.toFixed(0)} steps`
      }));

      const screenLineData = patternsData.map(d => ({
        x: d.day,
        y: d.avgScreenTime,
        metric: "Screen Time",
        value: `${d.avgScreenTime.toFixed(1)}h`
      }));

      const sleepLineData = patternsData.map(d => ({
        x: d.day,
        y: d.avgDeepSleep,
        metric: "Deep Sleep",
        value: `${d.avgDeepSleep.toFixed(1)}h`
      }));

      const allLineData = [...caffeineLineData, ...stepsLineData, ...screenLineData, ...sleepLineData];

      const chart = Plot.plot({
        width: Math.min(window.innerWidth - 100, 800),
        height: 350,
        style: {
          background: "white",
          color: "#0f172a",
          fontSize: "14px"
        },
        marginLeft: 60,
        marginRight: 30,
        marginBottom: 60,
        marginTop: 20,
        x: {
          label: "Day of Week"
        },
        y: {
          grid: true,
          label: "Average Value"
        },
        color: {
          legend: true,
          domain: ["Caffeine Rate", "Steps", "Screen Time", "Deep Sleep"],
          range: ["#f59e0b", "#10b981", "#ef4444", "#3b82f6"]
        },
        marks: [
          Plot.line(allLineData, {
            x: "x",
            y: "y",
            stroke: "metric",
            strokeWidth: 2,
            tip: true,
            title: (d) => `${d.x}: ${d.metric} ${d.value}`
          }),
          Plot.dot(allLineData, {
            x: "x",
            y: "y",
            fill: "metric",
            r: 4,
            stroke: "white",
            strokeWidth: 1,
            tip: true,
            title: (d) => `${d.x}: ${d.metric} ${d.value}`
          })
        ]
      });

      document.querySelector("#patterns-chart")?.append(chart);
    }

    // Load and render all data
    const sleepData = await fetchSleepData();
    console.log("Fetched sleep data:", sleepData); // Debug log
    
    createSleepChart(sleepData);
    createHabitsChart(sleepData);
    createPatternsChart(sleepData);

    // Handle window resize
    let resizeTimeout;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        document.querySelector("#sleep-chart").innerHTML = '';
        document.querySelector("#habits-chart").innerHTML = '';
        document.querySelector("#patterns-chart").innerHTML = '';
        createSleepChart(sleepData);
        createHabitsChart(sleepData);
        createPatternsChart(sleepData);
      }, 250);
    });
  </script>
</Layout>
