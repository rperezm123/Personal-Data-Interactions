---
import Layout from '../layouts/Layout.astro';
import MyButton from '../components/button.jsx';
import "../styles/global.css";
---

<Layout>
  <section class="min-h-screen bg-slate-50 px-6 py-10">
    <div class="mx-auto flex max-w-6xl flex-col gap-8">
      
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700">
          Experiment Mode
        </p>
        <h1 class="mt-2 text-4xl font-extrabold text-slate-900 md:text-6xl">
          Test one daily habit at a time
        </h1>
        <p class="mx-auto mt-4 max-w-3xl text-lg text-slate-600">
          Isolate one habit, keep the rest of your routine as stable as possible, and observe how it affects your deep sleep over time.
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-8">
          <h2 class="mb-6 text-2xl font-bold text-slate-900">Create a new experiment</h2>

          <form class="grid gap-6">
            <div>
              <label class="mb-2 block font-semibold text-slate-800">Experiment title</label>
              <input
                type="text"
                placeholder="e.g. No caffeine after 3 PM for 7 days"
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-sky-500"
              />
            </div>

            <div>
              <label class="mb-2 block font-semibold text-slate-800">Habit to isolate</label>
              <select class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-sky-500">
                <option value="">Select one habit</option>
                <option value="caffeine">Caffeine after 3 PM</option>
                <option value="screen-time">Screen time</option>
                <option value="phone-use">Last phone use time</option>
                <option value="steps">Daily steps</option>
                <option value="sleep-routine">Sleep routine consistency</option>
              </select>
            </div>

            <div>
              <label class="mb-2 block font-semibold text-slate-800">Experiment rule</label>
              <textarea
                rows="4"
                placeholder="e.g. Do not drink coffee after 3 PM during this experiment."
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-sky-500"
              ></textarea>
            </div>

            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <label class="mb-2 block font-semibold text-slate-800">Duration</label>
                <select class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-sky-500">
                  <option value="">Select duration</option>
                  <option value="3days">3 days</option>
                  <option value="7days">7 days</option>
                  <option value="14days">14 days</option>
                  <option value="30days">30 days</option>
                </select>
              </div>

              <div>
                <label class="mb-2 block font-semibold text-slate-800">Primary outcome</label>
                <select class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-sky-500">
                  <option value="">Select outcome</option>
                  <option value="deep-sleep">Deep sleep duration</option>
                  <option value="sleep-quality">Sleep quality</option>
                  <option value="total-sleep">Total sleep duration</option>
                </select>
              </div>
            </div>

            <div>
              <label class="mb-2 block font-semibold text-slate-800">Notes / hypothesis</label>
              <textarea
                rows="4"
                placeholder="e.g. I think reducing late caffeine will increase my deep sleep."
                class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none transition focus:border-sky-500"
              ></textarea>
            </div>

            <div class="flex flex-wrap gap-4 pt-2">
              <MyButton name="Start Experiment" />
              <a href="/dashboard">
                <MyButton name="Back to Dashboard" />
              </a>
            </div>
          </form>
        </div>

        <div class="flex flex-col gap-6">
          <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <h2 class="mb-4 text-2xl font-bold text-slate-900">Suggested experiments</h2>

            <div class="flex flex-col gap-4">
              <div class="rounded-2xl bg-sky-50 p-4">
                <p class="text-sm font-semibold uppercase tracking-wide text-sky-700">Caffeine test</p>
                <h3 class="mt-2 text-lg font-bold text-slate-900">No caffeine after 3 PM for 7 days</h3>
                <p class="mt-2 text-slate-600">
                  Keep the rest of your routine stable and compare deep sleep before and during the test.
                </p>
              </div>

              <div class="rounded-2xl bg-violet-50 p-4">
                <p class="text-sm font-semibold uppercase tracking-wide text-violet-700">Phone use test</p>
                <h3 class="mt-2 text-lg font-bold text-slate-900">No phone 1 hour before bed</h3>
                <p class="mt-2 text-slate-600">
                  Track whether reducing late phone use improves deep sleep and sleep quality.
                </p>
              </div>

              <div class="rounded-2xl bg-emerald-50 p-4">
                <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Activity test</p>
                <h3 class="mt-2 text-lg font-bold text-slate-900">Reach 8,000 steps daily for 2 weeks</h3>
                <p class="mt-2 text-slate-600">
                  Observe whether more physical activity is linked to better sleep outcomes.
                </p>
              </div>
            </div>
          </div>

          <div class="rounded-3xl border border-slate-200 bg-slate-900 p-6 text-white shadow-sm">
            <h2 class="mb-4 text-2xl font-bold">How to run a good experiment</h2>
            <ul class="flex list-disc flex-col gap-3 pl-5 text-slate-300">
              <li>Change only one habit at a time.</li>
              <li>Keep other routines as stable as possible.</li>
              <li>Track your sleep every day during the experiment.</li>
              <li>Compare deep sleep before and after the change.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
